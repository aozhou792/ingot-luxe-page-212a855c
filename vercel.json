{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ailibarbar.com" }],
      "destination": "https://www.ailibarbar.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/verify",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/abandoned-checkout",
      "schedule": "0 1 * * *"
    }
  ]
}
