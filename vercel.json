{
  "ignoreCommand": "test \"$VERCEL_GIT_COMMIT_REF\" = \"gh-pages\"",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ailibarbar.com" }],
      "destination": "https://www.ailibarbar.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/default.html",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/index.html",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/products/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/:path*.html",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/search/m",
      "destination": "/search",
      "statusCode": 301
    },
    {
      "source": "/search/m/:path*",
      "destination": "/search",
      "statusCode": 301
    },
    {
      "source": "/verify",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/contact-us",
      "destination": "/contact",
      "statusCode": 301
    },
    {
      "source": "/product/custom-3-pack",
      "destination": "/product/custom-5-pack",
      "statusCode": 301
    },
    {
      "source": "/guides/the-ultimate-guide-to-alibarbar-ingot-9000",
      "destination": "/guides/what-is-alibarbar-ingot-9000",
      "statusCode": 301
    },
    {
      "source": "/guides/disposable-vape-performance-australia",
      "destination": "/research/high-puff-disposable-capacity-australia-2026",
      "statusCode": 301
    },
    {
      "source": "/guides/flavours-ranking-vape-alibarbar",
      "destination": "/blog/top-alibarbar-flavours-ranked",
      "statusCode": 301
    },
    {
      "source": "/blog/best-disposable-vape-australia-2024",
      "destination": "/blog/best-disposable-vape-australia-2026",
      "statusCode": 301
    },
    {
      "source": "/blog/best-disposable-vape-australia-2023",
      "destination": "/blog/best-disposable-vape-australia-2026",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/cart",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/checkout",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/search",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/order-complete",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/abandoned-checkout",
      "schedule": "0 1 * * *"
    }
  ]
}
